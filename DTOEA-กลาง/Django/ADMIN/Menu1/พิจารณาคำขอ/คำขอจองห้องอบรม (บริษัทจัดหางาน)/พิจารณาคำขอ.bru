meta {
  name: พิจารณาคำขอ
  type: http
  seq: 1
}

post {
  url: http://apiserver:8080/admin/approve/
  body: json
  auth: inherit
}

body:json {
  {
      "action" : "approveRequest",
      "event" : "updateTraingRoomReq", //ถ้ามีปรับแก้ห้องอบรม ต้องส่ง event นี้มา
      "trtype": 2,
      "tscid": 10, //ถ้าเป็น อบรม ณสำนักงาน ต้องใส่มา
      "reqid" : 1434033,
      "apptype" : 1,
      "appstatus" : 1,
      "description" : "เหตุผลประกอบการพิจารณา"
  }
}

settings {
  encodeUrl: true
}
