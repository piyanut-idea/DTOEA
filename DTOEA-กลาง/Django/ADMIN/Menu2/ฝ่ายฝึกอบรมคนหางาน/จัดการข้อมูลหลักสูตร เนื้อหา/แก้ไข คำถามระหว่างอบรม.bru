meta {
  name: แก้ไข คำถามระหว่างอบรม
  type: http
  seq: 2
}

put {
  url: http://apiserver:8080/admin/questtraining/9/
  body: json
  auth: inherit
}

body:json {
  {
    "action" : "edit-questtraining",
    "title": "แกไขคำถามตัวอย่าง?",   // หัวข้อคำถาม
    "qstatus": 1,                // สถานะคำถาม (0=ไม่ใช้งาน, 1=ใช้งาน)
    "cchoice": 2,                // จำนวนตัวเลือก
    "choice_list" : [
      {
        "answer" : "ใช่", //ตัวเลือก
        "cstatus" : "1" //(1,"ถูกต้อง"),(2,"ไม่ถูกต้อง")
      },
      {
        "answer" : "ไม่ใช่", //ตัวเลือก
        "cstatus" : "2" //(1,"ถูกต้อง"),(2,"ไม่ถูกต้อง")
      }
    ]
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
