meta {
  name: trainingroom สร้างห้องอบรม อบรม ณ สำนักงาน
  type: http
  seq: 2
}

post {
  url: http://apiserver:8080/admin/trainingroom/
  body: json
  auth: inherit
}

body:json {
  {
      "action": "addTrainingroomInfo",
      "pvid": 32,
      "name": "ห้องอบรม A",
      "traintype" : 1,
      "status": 1,
      "trtype": 2 // ถ้าเลือกเป็น trtype : 1 อบรมออนไลน์ , 2 : อบรม ณ สำนักงาน
  }
  
}

settings {
  encodeUrl: true
}
