meta {
  name: trainingroom แก้ไข ห้องอบรม อบรม ออนไลน์
  type: http
  seq: 2
}

put {
  url: http://apiserver:8080/admin/trainingroom/5268/
  body: json
  auth: inherit
}

body:json {
  {
      "action": "editTrainingroomInfo",
      "pvid": 32,
      "name": "ห้องอบรม A",
      "traintype" : 1,
      "status": 1,
      "trtype": 1, // ถ้าเลือกเป็น trtype : 1 อบรมออนไลน์ , 2 : อบรม ณ สำนักงาน
      "cntid" : 1066,
      "course_list" : [
          {
              "csid" : 1
          },
          {
              "csid" : 2
          }
      ]
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
