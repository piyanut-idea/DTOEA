meta {
  name: บันทึกข้อมูลการอบรมส่วนที่ 1
  type: http
  seq: 10
}

post {
  url: http://apiserver:8080/admin/resultjptraingpridtl/
  body: json
  auth: inherit
}

body:json {
  {
    "actiontype": "result-record",  
    "rcid": 1,    // รหัสการสมัคร
    "result": 1,  // ผล 1=เข้าอบรม 2=สละสิทธิ์
    "gen": "1",  // รุ่นที่
    "idpri": "A001",  // ID การอบรม
    "startdate": "2026-03-31T00:00:00",  // วันที่เข้าศูนย์
    "remark": "เหตุผล",  // เหตุผล
    "editcause": "สาเหตุการแก้ไข"  // สาเหตุการแก้ไข
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
