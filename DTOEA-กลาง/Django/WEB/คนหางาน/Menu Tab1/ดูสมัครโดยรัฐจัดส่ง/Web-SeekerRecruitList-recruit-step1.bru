meta {
  name: Web-SeekerRecruitList-recruit-step1
  type: http
  seq: 2
}

put {
  url: http://apiserver:8080/web/seekerrecruit/1/
  body: json
  auth: inherit
}

body:json {
  {
      "actiontype":"recruit-step1",
    
      // ส่วนที่ 1: ผู้ดำเนินการบันทึกคำขอ
      "tsubmit": 1,
      "adid": 1, // update adname adposition
      "peoid": 1,
      "pincode": "1234",
    
      // ส่วนที่ 2: ตำแหน่งงาน
      "piid": 1,
    
      // ส่วนที่ 3: ประสบการณ์ทำงาน
      "ckwkis": 1,
      "ckexp": 1,
      "expyear": 2,
      "typework": 1,
      "prowork": 2,
      "license": 1,
      "interlicense": "1",
      // ส่วนที่ 4: สุขภาพ/ร่างกาย
      "ckcongen": 2,
      "congen": "",
      "eyecolor": 1,
      "disabled": 2,
      // ส่วนที่ 5: ข้อมูลอื่นๆ
      "kin": 2,
      "criminal": 2,
      "ckpay": 1,
      "othpay": ""
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
