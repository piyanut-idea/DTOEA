      "cadd" : "Editcadd", //ที่อยู่สถานที่ตั้งสถานประกอบการ
      "fcitid" : 1, //รหัสข้อมูลรัฐ / เขตการปกครอง/ เมือง
      "postcode" : "10220", //รหัสไปรษณีย์
      "tel" : "0925858784", //เบอร์โทรศัพท์
      "fax" : "1235456", //เบอร์โทรสาร
      "ctype" : "ctype", //ประเภทของบริษัท
      "effsdate" : "2026-03-03T00:00:00", //ช่วงเวลาที่มีผลบังคับใช้ (ตั้งแต่)
      "efftdate" : "2026-03-04T00:00:00", //ช่วงเวลาที่มีผลบังคับใช้ (ถึง)
      "editmessage" : "ใส่รายละเอียดเพราะเจ้าหน้าที่ส่งกลับมาให้แก้ไข", //รายละเอียดการแก้ไข
      "requestdoclist" : [
        {
          "id": 186, //fixed สำเนาใบอนุญาตจัดหางานให้คนหางานเพื่อไปทำงานในต่างประเทศ (จง. 6) ฉบับภาษาไทย และภาษาอังกฤษ
          "No": 1,
          "filename" : "edit_test1.pdf"
        },
        {
