meta {
  name: Step 1 (update) บันทึกข้อมูลใบอนุญาตประกอบกิจการจัดหางาน
  type: http
  seq: 4
}

put {
  url: http://apiserver:8080/web/senderreqlist/1/
  body: json
  auth: inherit
}

body:json {
  {
      "action" : "updateRequestSenderDtlStep1",
      "liceneno" : "EditNo7888889999999", //หมายเลขใบอนุญาต
