meta {
  name: เพิ่มข้อมูลผู้ประสานงานในประเทศญี่ปุ่น
  type: http
  seq: 6
}

post {
  url: http://apiserver:8080/web/orgsenderco/
  body: json
  auth: inherit
}

body:json {
  {
    "osid" : null, //id orgsenderinfo
    "cid" : 1, //id company
    "pfid" : 1, //รหัสคำนำหน้าชื่อ
    "fnameth": "เก่ง",      // ชื่อ (ไทย)
    "lnameth": "ใจดี",      // นามสกุล (ไทย)
    "fnameen": "Keng",      // ชื่อ (อังกฤษ)
    "lnameen": "Jaidee",      // นามสกุล (อังกฤษ)
    "orgnameth": "บริษัท เอ บี ซี จำกัด",    // ชื่อตัวแทน (บริษัท/องค์กร) (ไทย)
    "orgnameen": "ABC Company Limited",    // ชื่อตัวแทน (บริษัท/องค์กร) (อังกฤษ)
    "addressen": "Bangkok, Thailand",    // ที่อยู่ (อังกฤษ)
    "tel": "02-123-4567",          // เบอร์โทรศัพท์
    "fax": "02-123-4568",          // เบอร์โทรสาร
    "email": "somchai@example.com"         // อีเมล
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
